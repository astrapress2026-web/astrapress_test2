rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "astrapress2026@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Site Config: Anyone can read, only admin can write
    match /config/site {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Posts: Anyone can read, only admin can write
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Books: Anyone can read, only admin can write
    match /books/{bookId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users: Users can read/write their own profile, admin can read/write all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
